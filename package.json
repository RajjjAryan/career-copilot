{
  "name": "career-copilot",
  "version": "1.0.0",
  "description": "AI-powered job search pipeline built on GitHub Copilot CLI",
  "type": "module",
  "scripts": {
    "doctor": "node doctor.mjs",
    "verify": "node verify-pipeline.mjs",
    "normalize": "node normalize-statuses.mjs",
    "dedup": "node dedup-tracker.mjs",
    "merge": "node merge-tracker.mjs",
    "generate-instructions": "node scripts/generate-instructions.mjs",
    "detect-cli": "node scripts/detect-cli.mjs",
    "pdf": "node generate-pdf.mjs",
    "patterns": "node analyze-patterns.mjs",
    "sync-check": "node cv-sync-check.mjs",
    "liveness": "node check-liveness.mjs",
    "update:check": "node update-system.mjs check",
    "update": "node update-system.mjs apply",
    "rollback": "node update-system.mjs rollback",
    "test": "node test-all.mjs"
  },
  "keywords": ["ai", "job-search", "multi-cli", "copilot-cli", "claude-code", "gemini-cli", "cursor", "windsurf", "career", "automation", "resume", "cv"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/RajjjAryan/career-copilot.git"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "playwright": "^1.45.0"
  }
}
