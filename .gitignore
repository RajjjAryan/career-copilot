# Dependencies
node_modules/

# Output (generated, user-specific)
output/*
!output/.gitkeep

# Data (user-specific, not tracked)
data/applications.md
data/pipeline.md
data/scan-history.tsv
reports/*.md
!reports/.gitkeep
jds/*
!jds/.gitkeep
interview-prep/*
!interview-prep/.gitkeep
batch/tracker-additions/*.tsv
!batch/tracker-additions/.gitkeep
batch/logs/*
!batch/logs/.gitkeep
batch/batch-state.tsv
batch/batch-input.tsv

# User config (contains personal info)
config/profile.yml
modes/_profile.md
portals.yml
cv.md
article-digest.md

# Update system
.update-dismissed
.update-lock

# Generated
.resolved-prompt-*
career-dashboard

# OS
.DS_Store
*.mov
*.mp4
Thumbs.db

# IDE
.vscode/*
!.vscode/mcp.json
.idea/

# Claude Code local (if used alongside)
.claude/settings.local.json
.claude/memory/

# Temporary files
/tmp/
*.tmp
marketing/
